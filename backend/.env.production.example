# LinkPortal backend - PRODUCTION environment template
# Copy to ".env" on the server and fill in real values.
# NEVER commit the real .env (it is git-ignored).

# --- Server ---
PORT=4000
NODE_ENV=production
# Bind address. 127.0.0.1 = reachable only via the local reverse proxy (recommended).
# Set to 0.0.0.0 only if Node must be reachable directly (not recommended).
HOST=127.0.0.1

# --- Auth ---
# Generate a long random secret on the server, e.g.:  openssl rand -hex 48
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_48
JWT_EXPIRES_IN=8h

# --- CORS ---
# Public origin of the web app. With the same-origin nginx setup the web app does
# not strictly need CORS, but keep this accurate for hardening.
CORS_ORIGIN=https://linkportal.example.com

# --- Database (SQLite) ---
# Absolute path on the server, OUTSIDE the git tree so it survives deploys/pulls.
# Prisma also creates linkportal.db-wal / -shm next to this file.
DATABASE_URL="file:/opt/linkportal/data/linkportal.db"

# --- Seed admin (only used once by `npm run seed` on first setup) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_DISPLAYNAME=IT-Operations Admin
