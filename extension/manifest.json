{
  "manifest_version": 3,
  "name": "LinkPortal",
  "version": "1.0.0",
  "description": "IT-Operations link catalog – quick access to all your tools directly from the toolbar.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkPortal",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "notifications", "alarms"],
  "host_permissions": ["http://localhost:4000/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Open LinkPortal"
    }
  }
}
